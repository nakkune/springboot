<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.nak.backend.board.mapper.BoardGroupMapper">

    <resultMap id="BoardGroupResultMap" type="com.nak.backend.board.dto.BoardGroupDto">
        <id property="id" column="id" />
        <result property="boardId" column="board_id" />
        <result property="title" column="title" />
        <result property="color" column="color" />
        <result property="position" column="position" />
        <result property="isCollapsed" column="is_collapsed" />
        <result property="createdAt" column="created_at" />
        <result property="updatedAt" column="updated_at" />
    </resultMap>

    <select id="findAllByBoardId" resultMap="BoardGroupResultMap">
        SELECT * FROM board_groups WHERE board_id = #{boardId}::uuid ORDER BY position ASC, created_at ASC
    </select>

    <select id="findById" resultMap="BoardGroupResultMap">
        SELECT * FROM board_groups WHERE id = #{id}::uuid
    </select>

    <insert id="insert">
        INSERT INTO board_groups (id, board_id, title, color, position, is_collapsed, created_at, updated_at)
        VALUES (
            #{id}::uuid,
            #{boardId}::uuid,
            #{title},
            #{color},
            #{position},
            #{isCollapsed},
            COALESCE(#{createdAt}, NOW()),
            COALESCE(#{updatedAt}, NOW())
        )
    </insert>

    <update id="update">
        UPDATE board_groups
        SET title = #{title},
            color = #{color},
            position = #{position},
            is_collapsed = #{isCollapsed},
            updated_at = NOW()
        WHERE id = #{id}::uuid
    </update>

    <delete id="deleteById">
        DELETE FROM board_groups WHERE id = #{id}::uuid
    </delete>

</mapper>
