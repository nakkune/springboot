  created_at   DateTime?   @default(now()) @db.Timestamptz(6)
  users        users       @relation(fields: [actor_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  boards       boards?     @relation(fields: [board_id], references: [id], onUpdate: NoAction)
  items        items?      @relation(fields: [item_id], references: [id], onUpdate: NoAction)
